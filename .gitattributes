# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Python files
*.py text diff=python
*.pyi text diff=python
*.pyw text diff=python

# Binary files
*.pkl binary
*.pickle binary
*.db binary
*.sqlite3 binary
*.p binary

# Documents
*.md text diff=markdown
*.txt text
*.csv text
*.json text
*.xml text
*.yaml text
*.yml text
*.toml text

# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Graphics
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Archives
*.zip binary
*.gz binary
*.tar binary
